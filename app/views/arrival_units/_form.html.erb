<%= render "shared/form_errors", record: arrival_unit %>

<%= form_with model: arrival_unit, class: "form-layout", html: { autocomplete: "off" } do |form| %>
  <div class="form-grid">
    <div class="field-group">
      <%= form.label :name, "Arrival unit name" %>
      <%= form.text_field :name %>
    </div>

    <div class="field-group">
      <%= form.label :short_name, "Short name" %>
      <%= form.text_field :short_name %>
    </div>
  </div>

  <div class="inline-actions">
    <%= form.submit arrival_unit.persisted? ? "Update Arrival Unit" : "Create Arrival Unit", class: "button button-primary" %>
    <%= link_to "Back", arrival_units_path, class: "button button-ghost" %>
  </div>
<% end %>
