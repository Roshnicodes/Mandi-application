<div class="table-card report-sheet-card">
  <div class="sheet-header">
    <div>
      <p class="eyebrow">Call Sheet</p>
      <h2 class="table-title">Call performance</h2>
      <p class="table-subtitle">Total call, fully satisfied, call again aur wrong call numbers yahan capture honge.</p>
    </div>
    <div class="inline-actions">
      <%= link_to "Add Call Row", new_cotton_bulletin_cotton_call_performance_path(bulletin), class: "button button-secondary" %>
    </div>
  </div>

  <% if records.any? %>
    <div class="data-table-wrapper">
      <table class="report-grid-table">
        <thead>
          <tr>
            <th>S. No</th>
            <th>Total Call</th>
            <th>Fully Satisfied</th>
            <th>Satisfaction %</th>
            <th>Call Again</th>
            <th>Wrong Call</th>
            <th>Invalid / Exist</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% records.each_with_index do |record, index| %>
            <tr>
              <td><%= record.position.presence || index + 1 %></td>
              <td class="numeric-cell"><%= record.total_calls %></td>
              <td class="numeric-cell"><%= record.fully_satisfied %></td>
              <td class="numeric-cell"><%= record.satisfaction_percent.present? ? number_with_precision(record.satisfaction_percent, precision: 2) : "-" %></td>
              <td class="numeric-cell"><%= record.call_again %></td>
              <td class="numeric-cell"><%= record.wrong_call %></td>
              <td class="numeric-cell"><%= record.invalid_exist %></td>
              <td>
                <div class="inline-actions">
                  <%= link_to "Edit", edit_cotton_bulletin_cotton_call_performance_path(bulletin, record), class: "button button-secondary" %>
                  <%= button_to "Delete", cotton_bulletin_cotton_call_performance_path(bulletin, record), method: :delete, class: "button button-danger", form: { class: "button-to-inline" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="empty-state">Call performance rows abhi add nahi hui hain.</div>
  <% end %>
</div>
