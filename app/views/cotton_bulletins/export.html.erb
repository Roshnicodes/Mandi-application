<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <style>
      body {
        font-family: Calibri, Arial, sans-serif;
        font-size: 12pt;
        color: #000;
      }

      body.preview-mode {
        padding-top: 58px;
      }

      table {
        border-collapse: collapse;
      }

      td,
      th {
        border: 1px solid #000;
        padding: 3px 5px;
        vertical-align: middle;
        white-space: nowrap;
      }

      .sheet {
        width: 1720px;
      }

      .no-border {
        border: 0;
      }

      .title-cell {
        background: #f4dfcf;
        font-weight: 700;
      }

      .section-cell {
        background: #d9d4bd;
        font-weight: 700;
        text-align: center;
      }

      .left-section-cell {
        background: #d9d4bd;
        font-weight: 700;
      }

      .header-cell {
        background: #fff;
        font-weight: 700;
        text-align: center;
      }

      .tint-blue {
        background: #dbeef4;
      }

      .tint-lavender {
        background: #e4dfec;
      }

      .tint-peach {
        background: #fcd5b4;
      }

      .highlight-row td {
        background: #fce4d6;
      }

      .number-cell {
        text-align: right;
      }

      .center-cell {
        text-align: center;
      }

      .bold-cell {
        font-weight: 700;
      }

      .blank-row td {
        border-left: 0;
        border-right: 0;
        height: 18px;
      }

      .thick-top td,
      .thick-top th {
        border-top: 2px solid #000;
      }

      .thick-bottom td,
      .thick-bottom th {
        border-bottom: 2px solid #000;
      }

      .preview-toolbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 10px 14px;
        background: #ffffff;
        border-bottom: 1px solid #c8c8c8;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      }

      .preview-toolbar-title {
        font-family: Arial, sans-serif;
        font-size: 14px;
        font-weight: 700;
      }

      .preview-toolbar-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .preview-button {
        appearance: none;
        border: 1px solid #9ca3af;
        border-radius: 6px;
        background: #f8fafc;
        color: #111827;
        cursor: pointer;
        font-family: Arial, sans-serif;
        font-size: 13px;
        font-weight: 700;
        line-height: 1;
        padding: 9px 12px;
        text-decoration: none;
      }

      .preview-button.primary {
        background: #1d4ed8;
        border-color: #1d4ed8;
        color: #fff;
      }

      .preview-button:hover {
        background: #e5e7eb;
      }

      .preview-button.primary:hover {
        background: #1e40af;
      }

      @media print {
        body.preview-mode {
          padding-top: 0;
        }

        .preview-toolbar {
          display: none;
        }
      }
    </style>
  </head>
  <body class="<%= "preview-mode" if params[:preview].present? %>">
    <% report_date = @cotton_bulletin.report_date.strftime("%d %b - %Y") %>
    <% dash = ->(value) { value.present? ? value : "-" } %>
    <% number = ->(value) { value.present? ? number_with_precision(value, precision: 0, strip_insignificant_zeros: true) : "-" } %>
    <% percent = ->(value) { value.present? ? "#{number_with_precision(value, precision: 0, strip_insignificant_zeros: true)}%" : "-" } %>
    <% right_raw_rows = @gin_rows + @tdn_rows %>
    <% rows_count = [@mandi_rows.size + @cci_rows.size, right_raw_rows.size].max %>

    <% if params[:preview].present? %>
      <div class="preview-toolbar">
        <div class="preview-toolbar-title">Cotton Excel Preview - <%= report_date %></div>
        <div class="preview-toolbar-actions">
          <button type="button" class="preview-button" data-action="close-preview">Close Excel</button>
          <button type="button" class="preview-button" data-action="share-preview">Share Screenshot</button>
          <button type="button" class="preview-button" onclick="window.print()">Print</button>
          <%= link_to "Export Excel", export_cotton_bulletin_path(@cotton_bulletin), class: "preview-button primary" %>
        </div>
      </div>
    <% end %>

    <table class="sheet">
      <colgroup>
        <col style="width: 44px;">
        <col style="width: 190px;">
        <col style="width: 125px;">
        <col style="width: 120px;">
        <col style="width: 120px;">
        <col style="width: 90px;">
        <col style="width: 220px;">
        <col style="width: 12px;">
        <col style="width: 48px;">
        <col style="width: 210px;">
        <col style="width: 88px;">
        <col style="width: 84px;">
        <col style="width: 96px;">
        <col style="width: 74px;">
        <col style="width: 74px;">
        <col style="width: 74px;">
        <col style="width: 74px;">
        <col style="width: 74px;">
      </colgroup>

      <tbody>
        <tr>
          <td colspan="7" class="title-cell"><%= report_date %></td>
          <td class="no-border"></td>
          <td colspan="5" class="title-cell"><%= report_date %></td>
          <td colspan="5" class="no-border"></td>
        </tr>
        <tr>
          <td colspan="7" class="left-section-cell">Raw Cotton Rate</td>
          <td class="no-border"></td>
          <td colspan="5" class="left-section-cell">Raw Cotton Rate</td>
          <td colspan="5" class="no-border"></td>
        </tr>
        <tr class="thick-bottom">
          <td colspan="7" class="left-section-cell">Mandi Wise</td>
          <td class="no-border"></td>
          <td colspan="5" class="left-section-cell">GIN Wise</td>
          <td colspan="5" class="no-border"></td>
        </tr>
        <tr class="header-row thick-bottom">
          <th class="header-cell">S. No</th>
          <th class="header-cell">Mandi Name</th>
          <th class="header-cell">Arrival Qty<br>(In Qtl)</th>
          <th class="header-cell">Minimum Price</th>
          <th class="header-cell">Maximum Price</th>
          <th class="header-cell">Modal Price</th>
          <th class="header-cell">Reference / Remark</th>
          <td class="no-border"></td>
          <th class="header-cell">S. No</th>
          <th class="header-cell">Gin Name</th>
          <th class="header-cell">Arrival Qty<br>(In Qtl)</th>
          <th class="header-cell">Moisture</th>
          <th class="header-cell">Arrival Price</th>
          <td colspan="5" class="no-border"></td>
        </tr>

        <% left_rows = @mandi_rows + @cci_rows %>
        <% rows_count.times do |index| %>
          <% left = left_rows[index] %>
          <% gin = right_raw_rows[index] %>
          <tr class="<%= "highlight-row" if left && left[:name].to_s.include?("CCI") %>">
            <td class="center-cell"><%= left ? index + 1 : "" %></td>
            <td><%= left ? left[:name] : "" %></td>
            <td class="number-cell"><%= left ? number.call(left[:arrival_quantity]) : "" %></td>
            <td class="number-cell"><%= left ? number.call(left[:minimum_price]) : "" %></td>
            <td class="number-cell"><%= left ? number.call(left[:maximum_price]) : "" %></td>
            <td class="number-cell"><%= left ? number.call(left[:modal_price]) : "" %></td>
            <td><%= left ? dash.call(left[:remarks]) : "" %></td>
            <td class="no-border"></td>
            <td class="center-cell"><%= gin ? (gin.position.presence || index + 1) : "" %></td>
            <td><%= gin&.name %></td>
            <td class="number-cell"><%= gin ? number.call(gin.arrival_quantity) : "" %></td>
            <td><%= gin ? dash.call(gin.moisture) : "" %></td>
            <td><%= gin ? dash.call(gin.arrival_price) : "" %></td>
            <td colspan="5" class="no-border"></td>
          </tr>
        <% end %>

        <tr class="blank-row">
          <td colspan="18"></td>
        </tr>

        <tr class="thick-top">
          <td colspan="7" class="section-cell">Cotton Seed Rate</td>
          <td class="no-border"></td>
          <td colspan="10" class="no-border"></td>
        </tr>
        <tr>
          <td colspan="7" class="section-cell">Smart Info</td>
          <td class="no-border"></td>
          <td colspan="10" class="no-border"></td>
        </tr>
        <tr class="header-row">
          <th class="header-cell">S.no</th>
          <th class="header-cell">Particular</th>
          <th class="header-cell tint-blue">Madhya Pradesh</th>
          <th class="header-cell tint-blue">Odisha</th>
          <th class="header-cell tint-lavender">Maharashtra</th>
          <th class="header-cell"></th>
          <th class="header-cell">Reference</th>
          <td class="no-border"></td>
          <td colspan="10" class="no-border"></td>
        </tr>
        <% @seed_rows.each_with_index do |row, index| %>
          <tr>
            <td class="center-cell"><%= row.position.presence || index + 1 %></td>
            <td><%= row.particular %></td>
            <td class="number-cell"><%= dash.call(row.madhya_pradesh_rate) %></td>
            <td class="number-cell"><%= dash.call(row.odisha_rate) %></td>
            <td class="number-cell"><%= dash.call(row.maharashtra_rate) %></td>
            <td></td>
            <td><%= dash.call(row.reference) %></td>
            <td class="no-border"></td>
            <td colspan="10" class="no-border"></td>
          </tr>
        <% end %>

        <tr class="blank-row">
          <td colspan="18"></td>
        </tr>

        <tr class="thick-top">
          <td colspan="7" class="section-cell">Candy Rate (MCH)</td>
          <td class="no-border"></td>
          <td class="bold-cell">Price</td>
          <% %w[Raipur Ojhar Kukshi Pati Sausar Jobat Odisha].each do |place| %>
            <td class="bold-cell center-cell"><%= place %></td>
          <% end %>
          <td class="no-border"></td>
        </tr>
        <tr>
          <td colspan="7" class="section-cell">Smart Info</td>
          <td class="no-border"></td>
          <% regional = @regional_rows.first %>
          <% if regional %>
            <td class="bold-cell"><%= regional.line_item %></td>
            <td class="number-cell"><%= dash.call(regional.raipur_value) %></td>
            <td class="number-cell"><%= dash.call(regional.ojhar_value) %></td>
            <td class="number-cell"><%= dash.call(regional.kukshi_value) %></td>
            <td class="number-cell"><%= dash.call(regional.pati_value) %></td>
            <td class="number-cell"><%= dash.call(regional.sausar_value) %></td>
            <td class="number-cell"><%= dash.call(regional.jobat_value) %></td>
            <td class="number-cell"><%= dash.call(regional.odisha_value) %></td>
            <td class="number-cell"><%= dash.call(regional.extra_value_one) %></td>
          <% else %>
            <td colspan="10" class="no-border"></td>
          <% end %>
        </tr>
        <tr>
          <th class="header-cell">S. No</th>
          <th class="header-cell tint-peach">Parameter (29 mm)</th>
          <th class="header-cell tint-lavender">Madhya Pradesh<br>29 MM</th>
          <th class="header-cell tint-lavender">Maharashtra<br>29 MM</th>
          <th class="header-cell tint-lavender">Maharashtra<br>31 MM</th>
          <th class="header-cell tint-blue">Odisha<br>29 MM</th>
          <th class="header-cell tint-blue">Odisha<br>30 MM</th>
          <td class="no-border"></td>
          <% regional = @regional_rows.second %>
          <% if regional %>
            <td class="bold-cell"><%= regional.line_item %></td>
            <td class="number-cell"><%= dash.call(regional.raipur_value) %></td>
            <td class="number-cell"><%= dash.call(regional.ojhar_value) %></td>
            <td class="number-cell"><%= dash.call(regional.kukshi_value) %></td>
            <td class="number-cell"><%= dash.call(regional.pati_value) %></td>
            <td class="number-cell"><%= dash.call(regional.sausar_value) %></td>
            <td class="number-cell"><%= dash.call(regional.jobat_value) %></td>
            <td class="number-cell"><%= dash.call(regional.odisha_value) %></td>
            <td class="number-cell"><%= dash.call(regional.extra_value_one) %></td>
          <% else %>
            <td colspan="10" class="no-border"></td>
          <% end %>
        </tr>
        <% combined_mch_count = [@mch_rows.size, @regional_rows.drop(2).size].max %>
        <% combined_mch_count.times do |index| %>
          <% row = @mch_rows[index] %>
          <% regional = @regional_rows.drop(2)[index] %>
          <tr>
            <td class="center-cell"><%= row ? (row.position.presence || index + 1) : "" %></td>
            <td><%= row&.parameter %></td>
            <td class="number-cell"><%= row ? dash.call(row.madhya_pradesh_rate) : "" %></td>
            <td class="number-cell"><%= row ? dash.call(row.maharashtra_29mm_rate) : "" %></td>
            <td class="number-cell"><%= row ? dash.call(row.maharashtra_31mm_rate) : "" %></td>
            <td class="number-cell"><%= row ? dash.call(row.odisha_29mm_rate) : "" %></td>
            <td class="number-cell"><%= row ? dash.call(row.odisha_30mm_rate) : "" %></td>
            <td class="no-border"></td>
            <% if regional %>
              <td class="bold-cell"><%= regional.line_item %></td>
              <td class="number-cell"><%= dash.call(regional.raipur_value) %></td>
              <td class="number-cell"><%= dash.call(regional.ojhar_value) %></td>
              <td class="number-cell"><%= dash.call(regional.kukshi_value) %></td>
              <td class="number-cell"><%= dash.call(regional.pati_value) %></td>
              <td class="number-cell"><%= dash.call(regional.sausar_value) %></td>
              <td class="number-cell"><%= dash.call(regional.jobat_value) %></td>
              <td class="number-cell"><%= dash.call(regional.odisha_value) %></td>
              <td class="number-cell"><%= dash.call(regional.extra_value_one) %></td>
            <% else %>
              <td colspan="10" class="no-border"></td>
            <% end %>
          </tr>
        <% end %>

        <tr class="blank-row">
          <td colspan="18"></td>
        </tr>

        <tr class="thick-top">
          <td colspan="7" class="section-cell">Candy Rate (DCH)</td>
          <td class="no-border"></td>
          <td colspan="10" class="no-border"></td>
        </tr>
        <tr>
          <td colspan="7" class="section-cell">MM Service Wise</td>
          <td class="no-border"></td>
          <td colspan="10" class="no-border"></td>
        </tr>
        <tr class="header-row">
          <th class="header-cell">S. No</th>
          <th class="header-cell tint-peach">Parameter</th>
          <th class="header-cell tint-peach">Madhya Pradesh</th>
          <th class="header-cell"></th>
          <th class="header-cell"></th>
          <th class="header-cell"></th>
          <th class="header-cell"></th>
          <td class="no-border"></td>
          <td colspan="10" class="no-border"></td>
        </tr>
        <% @dch_rows.each_with_index do |row, index| %>
          <tr>
            <td class="center-cell"><%= row.position.presence || index + 1 %></td>
            <td><%= row.parameter %></td>
            <td class="number-cell"><%= dash.call(row.madhya_pradesh_rate) %></td>
            <td class="number-cell"><%= dash.call(row.maharashtra_29mm_rate) %></td>
            <td class="number-cell"><%= dash.call(row.maharashtra_31mm_rate) %></td>
            <td class="number-cell"><%= dash.call(row.odisha_29mm_rate) %></td>
            <td class="number-cell"><%= dash.call(row.odisha_30mm_rate) %></td>
            <td class="no-border"></td>
            <td colspan="10" class="no-border"></td>
          </tr>
        <% end %>

        <% if @comparison_rows.present? %>
          <tr class="blank-row">
            <td colspan="18"></td>
          </tr>
          <tr class="thick-top">
            <td colspan="7" class="section-cell">Comparison Sheet</td>
            <td class="no-border"></td>
            <td colspan="10" class="no-border"></td>
          </tr>
          <tr>
            <th class="header-cell">Date</th>
            <th class="header-cell">Total Arr</th>
            <th class="header-cell">Traders Buying</th>
            <th class="header-cell">Traders %</th>
            <th class="header-cell">CCI Buying</th>
            <th class="header-cell">CCI %</th>
            <th class="header-cell">Remark</th>
            <td class="no-border"></td>
            <td colspan="10" class="no-border"></td>
          </tr>
          <% @comparison_rows.each do |row| %>
            <tr>
              <td><%= (row.observation_date || @cotton_bulletin.report_date).strftime("%d-%b-%y") %></td>
              <td class="number-cell"><%= number.call(row.total_arrival) %></td>
              <td class="number-cell"><%= number.call(row.traders_buy) %></td>
              <td class="number-cell"><%= percent.call(row.traders_percentage) %></td>
              <td class="number-cell"><%= number.call(row.cci_buy) %></td>
              <td class="number-cell"><%= percent.call(row.effective_cci_percentage) %></td>
              <td><%= dash.call(row.remarks) %></td>
              <td class="no-border"></td>
              <td colspan="10" class="no-border"></td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>

    <% if params[:preview].present? %>
      <script>
        document.querySelector("[data-action='close-preview']").addEventListener("click", function () {
          if (window.opener) {
            window.close();
          } else {
            window.location.href = "<%= cotton_bulletin_path(@cotton_bulletin) %>";
          }
        });

        const downloadBlob = (blob, fileName) => {
          const link = document.createElement("a");
          const url = URL.createObjectURL(blob);

          link.href = url;
          link.download = fileName;
          document.body.appendChild(link);
          link.click();
          link.remove();
          window.setTimeout(() => URL.revokeObjectURL(url), 1000);
        };

        const renderSheetToImage = (sheet) => {
          const sheetRect = sheet.getBoundingClientRect();
          const width = Math.ceil(sheetRect.width);
          const height = Math.ceil(sheetRect.height);
          const maxCanvasPixels = 12000000;
          const maxSafeScale = Math.sqrt(maxCanvasPixels / Math.max(width * height, 1));
          const scale = Math.min(window.devicePixelRatio || 1, 2, maxSafeScale);

          return new Promise((resolve, reject) => {
            const canvas = document.createElement("canvas");
            canvas.width = Math.ceil(width * scale);
            canvas.height = Math.ceil(height * scale);

            const context = canvas.getContext("2d");
            context.scale(scale, scale);
            context.fillStyle = "#ffffff";
            context.fillRect(0, 0, width, height);

            sheet.querySelectorAll("td, th").forEach((cell) => {
              const rect = cell.getBoundingClientRect();
              const style = window.getComputedStyle(cell);
              const x = rect.left - sheetRect.left;
              const y = rect.top - sheetRect.top;
              const cellWidth = rect.width;
              const cellHeight = rect.height;
              const text = cell.textContent.trim();

              context.fillStyle = style.backgroundColor && style.backgroundColor !== "rgba(0, 0, 0, 0)" ? style.backgroundColor : "#ffffff";
              context.fillRect(x, y, cellWidth, cellHeight);

              if (style.borderTopStyle !== "none" && style.borderTopWidth !== "0px") {
                context.strokeStyle = style.borderTopColor || "#000000";
                context.lineWidth = Math.max(parseFloat(style.borderTopWidth) || 1, 1);
                context.strokeRect(x, y, cellWidth, cellHeight);
              }

              if (!text) return;

              const fontSize = parseFloat(style.fontSize) || 16;
              const fontFamily = style.fontFamily || "Calibri, Arial, sans-serif";
              const fontWeight = style.fontWeight || "400";
              const paddingLeft = parseFloat(style.paddingLeft) || 0;
              const paddingRight = parseFloat(style.paddingRight) || 0;
              const textAlign = style.textAlign;
              const font = `${fontWeight} ${fontSize}px ${fontFamily}`;

              context.fillStyle = style.color || "#000000";
              context.font = font;
              context.textBaseline = "middle";

              let textX = x + paddingLeft;
              if (textAlign === "right") {
                textX = x + cellWidth - paddingRight;
                context.textAlign = "right";
              } else if (textAlign === "center") {
                textX = x + (cellWidth / 2);
                context.textAlign = "center";
              } else {
                context.textAlign = "left";
              }

              context.fillText(text, textX, y + (cellHeight / 2), Math.max(cellWidth - paddingLeft - paddingRight, 0));
            });

            canvas.toBlob((blob) => {
              if (blob) {
                resolve(blob);
              } else {
                reject(new Error("Screenshot image could not be created."));
              }
            }, "image/png", 0.95);
          });
        };

        document.querySelector("[data-action='share-preview']").addEventListener("click", async function () {
          const button = this;
          const defaultLabel = button.textContent;
          const title = "Cotton Excel - <%= j report_date %>";
          const fileName = "cotton-excel-<%= @cotton_bulletin.report_date.strftime("%Y-%m-%d") %>.png";
          const sheet = document.querySelector(".sheet");

          if (!sheet) return;

          button.disabled = true;
          button.textContent = "Preparing...";

          try {
            const blob = await renderSheetToImage(sheet);
            const file = new File([blob], fileName, { type: "image/png" });

            if (navigator.canShare?.({ files: [file] }) && navigator.share) {
              try {
                await navigator.share({ title, files: [file] });
                button.textContent = "Shared";
                return;
              } catch (shareError) {
                console.error(shareError);
              }
            }

            if (navigator.clipboard?.write && window.ClipboardItem) {
              try {
                await navigator.clipboard.write([new ClipboardItem({ "image/png": blob })]);
                button.textContent = "Image Copied";
                return;
              } catch (clipboardError) {
                console.error(clipboardError);
              }
            }

            downloadBlob(blob, fileName);
            button.textContent = "Downloaded";
          } catch (error) {
            console.error(error);
            button.textContent = "Try Again";
          } finally {
            window.setTimeout(() => {
              button.disabled = false;
              button.textContent = defaultLabel;
            }, 1800);
          }
        });
      </script>
    <% end %>
  </body>
</html>
